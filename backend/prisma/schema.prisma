// ============================================================
// backend/prisma/schema.prisma
// Single source of truth for the HRMS database schema.
//
// After any change here, run:
//   npm run db:generate   (regenerate Prisma Client)
//   npm run db:migrate    (create and apply a new migration)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  admin
  hr
  employee
}

enum AttendanceStatus {
  present
  absent
  half_day
  work_from_home
  on_leave
}

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled
}

enum CompensationType {
  earning
  deduction
}

enum SalaryComponentName {
  basic
  hra
  conveyance_allowance
  medical_allowance
  special_allowance
  provident_fund
  professional_tax
  income_tax
}

// ─── Table 1: companies ──────────────────────────────────────

model Company {
  id          String       @id @default(uuid())
  name        String       @unique
  code        String       @unique
  address     String?
  phone       String?
  email       String?
  website     String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt      @map("updated_at")

  departments Department[]
  users       User[]

  @@map("companies")
}

// ─── Table 2: departments ────────────────────────────────────

model Department {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  name        String
  code        String
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobPositions JobPosition[]
  users        User[]

  @@unique([companyId, code])
  @@map("departments")
}

// ─── Table 3: job_positions ──────────────────────────────────

model JobPosition {
  id           String     @id @default(uuid())
  departmentId String     @map("department_id")
  title        String
  level        Int        @default(1)
  description  String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt      @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  users      User[]

  @@map("job_positions")
}

// ─── Table 4: users ──────────────────────────────────────────
// login_id format: <company_code> + first2(firstName) + last2(lastName)
//                  + hireYear + 3-digit serial   e.g. ACarma2024001

model User {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  loginId       String   @unique @map("login_id")
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          UserRole @default(employee)
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  phone         String?
  departmentId  String?  @map("department_id")
  jobPositionId String?  @map("job_position_id")
  managerId     String?  @map("manager_id")
  hireDate            DateTime @map("hire_date") @db.Date
  isActive            Boolean  @default(true)  @map("is_active")
  mustChangePassword  Boolean  @default(false) @map("must_change_password")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt      @map("updated_at")

  // Relations
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobPosition     JobPosition?     @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  manager         User?            @relation("ReportsTo", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates    User[]           @relation("ReportsTo")
  profile         EmployeeProfile?
  bankDetail      BankDetail?
  skills          Skill[]
  certifications  Certification[]
  attendance      Attendance[]
  leaveAllocations LeaveAllocation[]
  leaveRequests   LeaveRequest[]   @relation("LeaveRequester")
  reviewedLeaves  LeaveRequest[]   @relation("LeaveReviewer")
  salaryStructure SalaryStructure?

  @@map("users")
}

// ─── Table 5: employee_profiles ──────────────────────────────

model EmployeeProfile {
  id                    String    @id @default(uuid())
  userId                String    @unique @map("user_id")
  dateOfBirth           DateTime? @map("date_of_birth")       @db.Date
  gender                String?
  address               String?
  city                  String?
  state                 String?
  pincode               String?
  nationality           String?   @default("Indian")
  maritalStatus         String?   @map("marital_status")
  avatarUrl             String?   @map("avatar_url")
  emergencyContactName  String?   @map("emergency_contact_name")
  emergencyContactPhone String?   @map("emergency_contact_phone")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

// ─── Table 6: bank_details ───────────────────────────────────

model BankDetail {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  accountNumber String   @map("account_number")
  bankName      String   @map("bank_name")
  ifscCode      String   @map("ifsc_code")
  accountType   String   @default("savings") @map("account_type")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_details")
}

// ─── Table 7: skills ─────────────────────────────────────────

model Skill {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  proficiency String?  @default("intermediate")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("skills")
}

// ─── Table 8: certifications ─────────────────────────────────

model Certification {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  name         String
  issuingOrg   String    @map("issuing_org")
  issueDate    DateTime  @map("issue_date")  @db.Date
  expiryDate   DateTime? @map("expiry_date") @db.Date
  credentialId String?   @map("credential_id")
  createdAt    DateTime  @default(now())     @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

// ─── Table 9: attendance ─────────────────────────────────────
// check_in / check_out store full TIMESTAMPTZ (date + time).
// The separate `date` field (DATE only) drives the unique constraint.

model Attendance {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  date      DateTime         @db.Date
  checkIn   DateTime?        @map("check_in")  @db.Timestamptz(3)
  checkOut  DateTime?        @map("check_out") @db.Timestamptz(3)
  status    AttendanceStatus @default(present)
  note      String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendance")
}

// ─── Table 10: leave_types ───────────────────────────────────

model LeaveType {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  isPaid          Boolean  @default(true) @map("is_paid")
  maxDaysPerYear  Int      @map("max_days_per_year")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  allocations LeaveAllocation[]
  requests    LeaveRequest[]

  @@map("leave_types")
}

// ─── Table 11: leave_allocations ────────────────────────────

model LeaveAllocation {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  leaveTypeId String   @map("leave_type_id")
  year        Int
  totalDays   Int      @map("total_days")
  usedDays    Int      @default(0) @map("used_days")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@unique([userId, leaveTypeId, year])
  @@map("leave_allocations")
}

// ─── Table 12: leave_requests ────────────────────────────────

model LeaveRequest {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  leaveTypeId  String      @map("leave_type_id")
  startDate    DateTime    @map("start_date")  @db.Date
  endDate      DateTime    @map("end_date")    @db.Date
  daysCount    Int         @map("days_count")
  reason       String?
  status       LeaveStatus @default(pending)
  reviewedById String?     @map("reviewed_by_id")
  reviewedAt   DateTime?   @map("reviewed_at")
  reviewerNote String?     @map("reviewer_note")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt      @map("updated_at")

  user       User      @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  leaveType  LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  reviewedBy User?     @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("leave_requests")
}

// ─── Table 13: salary_structures ────────────────────────────
// One active structure per employee (enforced by @unique userId)

model SalaryStructure {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  effectiveFrom DateTime @map("effective_from") @db.Date
  ctc           Decimal  @db.Decimal(12, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  components SalaryComponent[]

  @@map("salary_structures")
}

// ─── Table 14: salary_components ────────────────────────────
// Line-items (Basic, HRA, PF deduction, etc.) per salary structure.
// type=earning adds to gross pay; type=deduction subtracts from net pay.

model SalaryComponent {
  id                String              @id @default(uuid())
  salaryStructureId String              @map("salary_structure_id")
  name              SalaryComponentName
  type              CompensationType
  amount            Decimal             @db.Decimal(12, 2)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt      @map("updated_at")

  salaryStructure SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  @@map("salary_components")
}
