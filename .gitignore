# ============================================================
# HRMS Monorepo — Root .gitignore
# Covers: frontend (Next.js), backend (Express), and OS/IDE
# ============================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# --- Environment variables (NEVER commit secrets) ---
.env
.env.*
!.env.example

# --- Next.js build output ---
.next/
out/

# --- TypeScript / backend build output ---
dist/
build/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# --- Runtime data ---
pids/
*.pid
*.seed
*.pid.lock

# --- Coverage / test artifacts ---
coverage/
*.lcov
.nyc_output/

# --- Cache ---
.eslintcache
.stylelintcache
*.tsbuildinfo
.cache/

# --- OS generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- IDEs / editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Misc ---
*.tgz
package-lock.json.bak
